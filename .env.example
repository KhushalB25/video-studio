# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored and never committed.

# Anthropic API key — for LLM-based retake detection + plan authoring
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Pexels API key — for stock photo/video search inside the editor
# Get one (free, instant) at: https://www.pexels.com/api/
PEXELS_API_KEY=
